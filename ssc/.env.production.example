# Production Environment Variables
# Copy this to .env.production and fill in real values

# BSC Mainnet Configuration
PRIVATE_KEY=your_deployer_private_key_here
BSC_MAINNET_URL=https://bsc-dataseed.binance.org/
BSCSCAN_API_KEY=your_bscscan_api_key_here

# PostgreSQL Production Database
DATABASE_URL=postgresql://ssc_user:STRONG_PASSWORD_HERE@localhost:5432/ssc_production

# Redis Production
REDIS_URL=redis://localhost:6379

# JWT Configuration
# Generate with: `openssl rand -hex 64`
JWT_SECRET=generate_a_strong_random_secret_here_64_chars
JWT_REFRESH_SECRET=generate_another_strong_random_secret_here_64_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Application
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@yourdomain.com

# BSC Mainnet Contract Addresses (after deployment)
SSC_TOKEN_PROXY_ADDRESS=0x...
SSC_TOKEN_IMPL_ADDRESS=0x...
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_CHAIN_ID=56

# Monitoring (optional)
# SENTRY_DSN=https://your-sentry-dsn
# PROMETHEUS_PORT=9090

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
