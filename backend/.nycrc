{
  "all": true,
  "include": ["src/**/*.js"],
  "exclude": [
    "src/config/prisma.js",
    "src/index.js",
    "tests/**/*.js",
    "node_modules/**"
  ],
  "reporter": ["text", "lcov", "html"],
  "report-dir": "coverage",
  "check-coverage": true,
  "branches": 60,
  "lines": 60,
  "functions": 60,
  "statements": 60
}
