{
  "name": "dj-technologies-backend",
  "version": "0.1.0",
  "private": true,
  "description": "API backend for AI-powered website platform",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "test:setup": "node tests/setup.js",
    "test": "node --test tests/**/*.test.js",
    "test:ci": "npm run test:setup && node --test tests/**/*.test.js",
    "test:coverage": "nyc --all --reporter=text --include='src/**/*.js' npm test",
    "lint": "echo 'linting configured later'"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "pg": "^8.13.0",
    "razorpay": "^2.9.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "nyc": "^18.0.0",
    "prisma": "^7.6.0",
    "proxyquire": "^2.1.3",
    "sinon": "^21.0.3",
    "supertest": "^7.2.2"
  }
}
