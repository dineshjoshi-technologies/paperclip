// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String              @id @default(uuid())
  email             String              @unique
  passwordHash      String              @map("password_hash")
  name              String?
  avatar            String?
  role              Role                @default(USER)
  emailVerified     Boolean             @default(false) @map("email_verified")
  verificationToken String?             @map("verification_token")
  onboardingStep    Int                 @default(0) @map("onboarding_step")
  onboardingStartedAt DateTime?         @map("onboarding_started_at")
  onboardingCompletedAt DateTime?       @map("onboarding_completed_at")
  websites          Website[]
  refreshTokens     RefreshToken[]
  apiKeys           ApiKey[]
  passwordResetTokens PasswordResetToken[]
  subscriptions     Subscription[]
  payments          Payment[]
  invoices          Invoice[]
  emailLogs         EmailLog[]
  onboardingMilestones UserOnboardingMilestone[]
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime  @map("expires_at")
  revoked     Boolean   @default(false)
  replacedBy  String?   @map("replaced_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("refresh_tokens")
}

model ApiKey {
  id          String    @id @default(uuid())
  keyHash     String    @map("key_hash")
  name        String
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("api_keys")
}

model PasswordResetToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime  @map("expires_at")
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

model Website {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  slug        String      @unique
  status      WebsiteStatus @default(DRAFT)
  templateId  String?     @map("template_id")
  template    Template?   @relation(fields: [templateId], references: [id])
  config      Json?
  pages       Page[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([templateId])
  @@index([status])
  @@map("websites")
}

model Template {
  id          String    @id @default(uuid())
  name        String
  description String?
  category    String?
  previewUrl  String?   @map("preview_url")
  config      Json?
  isPremium   Boolean   @default(false) @map("is_premium")
  websites    Website[]
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([category])
  @@index([isPremium])
  @@map("templates")
}

model Page {
  id          String    @id @default(uuid())
  websiteId   String    @map("website_id")
  website     Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  content     Json?
  isPublished Boolean   @default(false) @map("is_published")
  components  Component[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([websiteId, slug])
  @@map("pages")
}

model Component {
  id        String    @id @default(uuid())
  pageId    String    @map("page_id")
  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String    // e.g., "hero", "features", "pricing", "footer"
  config    Json?     // Component-specific configuration
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("components")
}

enum Role {
  USER
  ADMIN
  AGENCY
  DEVELOPER
  DESIGNER
  SUPPORT
  SUPER_ADMIN
}

enum WebsiteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model EmailLog {
  id            String        @id @default(uuid())
  userId        String?       @map("user_id")
  user          User?         @relation(fields: [userId], references: [id])
  emailType     EmailType     @map("email_type")
  recipient     String
  subject       String
  status        EmailStatus   @default(PENDING) @map("status")
  errorMessage  String?       @map("error_message")
  attempts      Int           @default(0) @map("attempts")
  sentAt        DateTime?     @map("sent_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([userId])
  @@index([emailType])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("email_logs")
}

enum EmailType {
  WELCOME
  EMAIL_VERIFICATION
  PASSWORD_RESET
  WEBSITE_PUBLISHED
  PAYMENT_CONFIRMATION
  PAYMENT_FAILED
  SUBSCRIPTION_EXPIRED
  ADMIN_NEW_USER
  ADMIN_ABUSE_REPORT
  ADMIN_SUPPORT_TICKET
  ONBOARDING
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_CANCELLED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

model UserOnboardingMilestone {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestone     String    // e.g., "first_website", "first_template", "first_publish"
  awardedAt     DateTime  @default(now()) @map("awarded_at")

  @@unique([userId, milestone])
  @@map("user_onboarding_milestones")
}

model Subscription {
  id                    String            @id @default(uuid())
  userId                String            @map("user_id")
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                  SubscriptionPlan  @default(BASIC)
  provider              String            @default("razorpay") // "razorpay" or "stripe"
  providerSubscriptionId String?           @unique @map("provider_subscription_id")
  providerCustomerId    String?           @map("provider_customer_id")
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime          @map("current_period_start")
  currentPeriodEnd     DateTime          @map("current_period_end")
  cancelAtPeriodEnd    Boolean           @default(false) @map("cancel_at_period_end")
  payments             Payment[]
  invoices             Invoice[]
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([providerSubscriptionId])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model Payment {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId    String?       @map("subscription_id")
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  amount            Int           @default(0) // in paise/cents
  currency          String        @default("INR")
  provider          String        @default("razorpay")
  providerPaymentId String?       @unique @map("provider_payment_id")
  status            PaymentStatus @default(PENDING)
  method            String?       // "card", "upi", "netbanking", etc.
  email             String?
  contact          String?
  description       String?
  errorCode         String?       @map("error_code")
  errorMessage      String?       @map("error_message")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  invoices          Invoice[]

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([providerPaymentId])
  @@map("payments")
}

model Invoice {
  id                String        @id @default(uuid())
  invoiceNumber     String        @unique @map("invoice_number")
  userId            String        @map("user_id")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId    String?       @map("subscription_id")
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  paymentId         String?       @unique @map("payment_id")
  payment           Payment?      @relation(fields: [paymentId], references: [id])
  amount            Int           // in paise/cents
  tax               Int           @default(0) // in paise/cents
  total             Int           // amount + tax
  currency          String        @default("INR")
  status            InvoiceStatus @default(DRAFT)
  dueDate           DateTime      @map("due_date")
  issuedAt          DateTime      @default(now()) @map("issued_at")
  paidAt            DateTime?     @map("paid_at")
  lineItems         Json?         @map("line_items") // [{description, amount, quantity}]
  notes             String?
  metadata          Json?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([userId])
  @@index([invoiceNumber])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("invoices")
}

model PaymentGateway {
  id            String    @id @default(uuid())
  provider      String    @unique // "razorpay" or "stripe"
  enabled       Boolean  @default(true)
  keyId         String?   @map("key_id")
  keySecret     String?   @map("key_secret")
  webhookSecret String?   @map("webhook_secret")
  testMode      Boolean  @default(true) @map("test_mode")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("payment_gateways")
}

enum SubscriptionPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
  TRIALING
}

enum PaymentStatus {
  PENDING
  PROCESSING
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}